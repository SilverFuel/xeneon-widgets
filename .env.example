# XENEON Edge Host environment template
#
# Normal Windows installs do not require environment variables. The app stores
# user settings locally and protects integration secrets with per-user storage.

# Optional: point GPU Power telemetry at a specific HWiNFO sensor CSV.
# XENON_HWINFO_LOG=C:\path\to\HWiNFO-log.csv
# XENON_HWINFO_LOG_DIR=C:\path\to\folder

# Optional: macOS beta notarization, used only by scripts/notarize-macos.sh.
# APPLE_ID=developer@example.com
# APPLE_TEAM_ID=TEAMID1234
# APPLE_APP_SPECIFIC_PASSWORD=app-specific-password
