{
  "name": "xeneon-widgets",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/SilverFuel/xeneon-widgets.git"
  },
  "scripts": {
    "start": "powershell -ExecutionPolicy Bypass -File .\\start-xeneon.ps1",
    "check": "npm run check:js && npm run check:setup-guide && npm run check:bridge-boundaries && npm run check:observability && npm run check:dependency-pins && npm run check:support-redaction && npm run check:display-recovery && npm run check:unifi-form && npm run test:bridge-api && npm run check:app",
    "check:js": "node scripts/check-js.mjs",
    "check:setup-guide": "node scripts/check-setup-guide.mjs",
    "check:bridge-boundaries": "node scripts/check-bridge-boundaries.mjs",
    "check:observability": "node scripts/check-observability.mjs",
    "check:dependency-pins": "node scripts/check-dependency-pins.mjs",
    "check:support-redaction": "node scripts/check-support-redaction.mjs",
    "check:display-recovery": "node scripts/check-display-recovery.mjs",
    "check:unifi-form": "node scripts/check-unifi-form-draft.mjs",
    "check:app": "dotnet build app\\XenonEdgeHost.sln --configuration Release",
    "test:bridge-api": "node scripts/test-bridge-api.mjs",
    "audit:deps": "npm audit --audit-level=moderate && npm --prefix desktop/electron audit --audit-level=moderate && dotnet list app\\XenonEdgeHost.sln package --vulnerable --include-transitive",
    "clean": "powershell -ExecutionPolicy Bypass -File .\\scripts\\clean-workspace.ps1",
    "installer": "powershell -ExecutionPolicy Bypass -File .\\app\\build-installer.ps1",
    "release:gauntlet": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-release-gauntlet.ps1 -AllowGitHubSupportPath -AllowUnsignedBeta",
    "release:free-beta": "powershell -ExecutionPolicy Bypass -File .\\scripts\\prepare-free-beta-release.ps1",
    "release:ready": "powershell -ExecutionPolicy Bypass -File .\\scripts\\assert-release-ready.ps1 -AllowGitHubSupportPath",
    "release:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-release.ps1",
    "mac:install": "npm --prefix desktop/electron install",
    "mac:start": "npm --prefix desktop/electron start",
    "mac:dist": "npm --prefix desktop/electron run dist:mac",
    "bridge": "node bridge/server.mjs",
    "bridge:install": "powershell -ExecutionPolicy Bypass -File .\\bridge\\install-bridge.ps1",
    "bridge:uninstall": "powershell -ExecutionPolicy Bypass -File .\\bridge\\uninstall-bridge.ps1"
  },
  "engines": {
    "node": ">=20"
  }
}
